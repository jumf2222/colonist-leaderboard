{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "categories": {
        "correctness": "warn",
        "pedantic": "warn",
        "perf": "warn"
    },
    "rules": {
        "max-lines-per-function": "off",
        "max-lines": "off",
        "strict-boolean-expressions": "off"
    },
    "options": {
        "typeAware": true,
        "typeCheck": true
    }
}
